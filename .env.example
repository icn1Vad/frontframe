# Same-origin V1 API proxy target. Keep this server-only; do not prefix with NEXT_PUBLIC_.
# API_BACKEND_ORIGIN=https://business.example.com
# HTTP Adapter 接入后，getServerSideProps 使用该地址创建请求级服务实例。

# Frontend-only WPS demo. It does not connect contract tasks to a business backend.
# WPS_WEB_OFFICE_SDK_URL=/vendor/web-office-sdk-solution.umd.js
# WPS_WEB_OFFICE_APP_ID=your-wps-application-id
# WPS_WEB_OFFICE_FILE_ID=proofspace_demo_contract
# WPS_WEB_OFFICE_ENDPOINT=https://o.wpsgo.com
# WPS_WEB_OFFICE_MODE=normal
# WPS_WEB_OFFICE_READONLY=false
# WPS_DEMO_FILE_URL=https://example.com/demo/wps/test-contract.docx
