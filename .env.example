# Same-origin V1 API proxy target. Keep this server-only; do not prefix with NEXT_PUBLIC_.
# API_BACKEND_ORIGIN=https://business.example.com
# HTTP Adapter 接入后，getServerSideProps 使用该地址创建请求级服务实例。

# Preferred production setup: proxy a short-lived editor session from the backend business service.
# CONTRACT_EDITOR_SESSION_ENDPOINT=https://business.example.com/api/contract-review/tasks/{taskId}/editor-session
# CONTRACT_EDITOR_SESSION_TOKEN=server-to-server-token

# Local WPS WebOffice integration fallback. Do not use a long-lived token in production.
# WPS_WEB_OFFICE_SDK_URL=/vendor/web-office-sdk-solution-v1.1.27.umd.js
# WPS_WEB_OFFICE_APP_ID=your-wps-application-id
# WPS_WEB_OFFICE_FILE_ID=optional-fixed-file-id-for-local-testing
# WPS_WEB_OFFICE_TOKEN=optional-local-test-token
# WPS_WEB_OFFICE_TOKEN_TIMEOUT_MS=600000
# WPS_WEB_OFFICE_ENDPOINT=https://o.wpsgo.com
# WPS_WEB_OFFICE_MODE=normal
