# Explicitly opt the browser into the current Java delivery slice.
# false keeps every module on Mock; true enables auth, chat, classification,
# classification-pool, knowledge and review-read HTTP adapters.
NEXT_PUBLIC_PROOFSPACE_JAVA_SLICE=false

# Same-origin V1 API proxy target. Keep this server-only; do not prefix with NEXT_PUBLIC_.
# API_BACKEND_ORIGIN=https://business.example.com
# HTTP Adapter 接入后，getServerSideProps 使用该地址创建请求级服务实例。

# WPS AppID、fileId、SDK URL 和短期 Token 均由已认证的 Java API 动态下发。
# 不要在前端环境变量、模板或仓库中配置 AppSecret、编辑 Token 或固定 fileId。
